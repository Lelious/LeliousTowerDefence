{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "0a96c9f044f44dfb85d0c19882f8e22a",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "SampleAnimation (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 170.00001525878907,
            "y": -204.0,
            "width": 243.9999542236328,
            "height": 350.0000305175781
        }
    },
    "m_Slots": [
        {
            "m_Id": "cf10a0fe1f824298ba85e83b51e44d02"
        },
        {
            "m_Id": "6cfdc2b95bcf465399920962070bd651"
        },
        {
            "m_Id": "fddca5037791447a94f4705f32f177f3"
        },
        {
            "m_Id": "25859a394a5b41fd8c9f18f22529939f"
        },
        {
            "m_Id": "f021df8062c9444aaebdfcf96d2028f5"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "SampleAnimation",
    "m_FunctionSource": "15ce54de115a4bf47ad35d19d9270c0f",
    "m_FunctionBody": "void SampleAnimation_float(in UnityTexture2D animationTexture,\r\n\t\t\t\t\t\t\tin float3 vertexId, in float time, in float frameRate,\r\n\t\t\t\t\t\t\tout float3 position, out float3 normal)\r\n{\r\n\tfloat frameCount = animationTexture.texelSize.z;\r\n\tfloat duration = frameCount / frameRate;\r\n\tfloat normalizedTime = (time / duration) % 1;\r\n\r\n\tfloat positionY = (vertexId * 2 + 0.5) * animationTexture.texelSize.y;\r\n\tfloat2 positionUv = float2(normalizedTime, positionY);\r\n\tposition = animationTexture.SampleLevel(animationTexture.samplerstate, positionUv, 0).xyz;\r\n\r\n\tfloat normalY = (vertexId * 2 + 0.5) * animationTexture.texelSize.y;\r\n\tfloat2 normalUv = float2(normalizedTime, normalY);\r\n\tnormal = animationTexture.SampleLevel(animationTexture.samplerstate, normalUv, 0).xyz;\r\n}"
}

